---
---
<section class="hero-section">
  <div class="container hero-inner">
    <div class="hero-content" data-fade>
      <div class="hero-avail"><span class="avail-dot"></span>Disponible para proyectos</div>
      <h1>Diseño &amp; desarrollo<br><span class="purple">que convierte.</span></h1>
      <p class="hero-sub">Soy <strong>Samuel Castro</strong>, desarrollador web especializado en WordPress y React. Construyo sitios rápidos, optimizados y orientados a resultados.</p>
      <div class="hero-btns">
        <a href="#proyectos" class="btn-fill">Ver proyectos</a>
        <a href="#contacto" class="btn-outline"><i class="ti ti-mail" aria-hidden="true"></i>Hablemos</a>
      </div>
      <div class="hero-socials">
        <a href="https://www.linkedin.com/in/samuelcastrodev/" target="_blank" rel="noopener" aria-label="LinkedIn"><i class="ti ti-brand-linkedin"></i></a>
        <a href="https://github.com/ThisSC" target="_blank" rel="noopener" aria-label="GitHub"><i class="ti ti-brand-github"></i></a>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-card">
        <div class="hero-card-glow"></div>
        <div class="hero-card-inner">
          <div class="avatar-ring">
            <span class="avatar-initials">SC</span>
          </div>
          <div class="hero-card-name">Samuel Castro</div>
          <div class="hero-card-role">Frontend &amp; WordPress Dev</div>
          <div class="hero-tag-row">
            <span class="hero-tag-pill">React</span>
            <span class="hero-tag-pill">WordPress</span>
            <span class="hero-tag-pill">Node.js</span>
          </div>
          <div class="hero-card-stats">
            <div class="stat-item"><span class="stat-num">3+</span><span class="stat-label">Proyectos</span></div>
            <div class="stat-div"></div>
            <div class="stat-item"><span class="stat-num">5+</span><span class="stat-label">Tecnologías</span></div>
            <div class="stat-div"></div>
            <div class="stat-item"><span class="stat-num">100%</span><span class="stat-label">Dedicación</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-section { padding: 6.5rem 0 5.5rem; border-bottom: 0.5px solid var(--border); }
.hero-inner { display: grid; grid-template-columns: 1fr 300px; gap: 4rem; align-items: center; }
.hero-avail { display: inline-flex; align-items: center; gap: 7px; font-size: 11px; color: var(--green); margin-bottom: 1.5rem; letter-spacing: 0.06em; }
.avail-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); animation: pulse 2s infinite; flex-shrink: 0; }
h1 { font-size: 56px; font-weight: 600; letter-spacing: -0.04em; line-height: 1.06; color: var(--text); margin-bottom: 1.25rem; }
h1 .purple { color: var(--purple); }
.hero-sub { font-size: 15px; color: var(--muted); max-width: 430px; line-height: 1.8; margin-bottom: 2rem; font-weight: 300; }
.hero-sub strong { color: var(--text2); font-weight: 500; }
.hero-btns { display: flex; gap: 10px; margin-bottom: 2rem; flex-wrap: wrap; }
.hero-socials { display: flex; gap: 8px; }
.hero-socials a { width: 36px; height: 36px; border-radius: 8px; border: 0.5px solid var(--border2); display: flex; align-items: center; justify-content: center; color: var(--muted); text-decoration: none; font-size: 18px; transition: all 0.15s; }
.hero-socials a:hover { color: var(--purple); border-color: var(--purple-dim); background: var(--purple-bg); }

.hero-visual { display: flex; justify-content: flex-end; }
.hero-card { position: relative; width: 260px; }
.hero-card-glow { position: absolute; inset: -1px; border-radius: 17px; background: linear-gradient(135deg, var(--purple-dim) 0%, transparent 65%); opacity: 0.45; z-index: 0; }
.hero-card-inner { position: relative; z-index: 1; background: var(--bg2); border: 0.5px solid var(--border2); border-radius: 16px; padding: 1.75rem 1.5rem; display: flex; flex-direction: column; align-items: center; gap: 0.6rem; }
.avatar-ring {
  width: 86px; height: 86px;
  border-radius: 50%;
  border: 2px solid var(--purple-dim);
  background: var(--purple-bg);
  margin-bottom: 0.2rem;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-initials {
  font-size: 26px;
  font-weight: 600;
  color: var(--purple);
  letter-spacing: -0.04em;
  line-height: 1;
  user-select: none;
}
.hero-card-name { font-size: 14px; font-weight: 600; color: var(--text); }
.hero-card-role { font-size: 11px; color: var(--muted); }
.hero-tag-row { display: flex; gap: 5px; flex-wrap: wrap; justify-content: center; }
.hero-tag-pill { font-size: 10px; background: var(--purple-bg); color: var(--purple); border: 0.5px solid var(--purple-dim); padding: 2px 9px; border-radius: 20px; letter-spacing: 0.04em; }
.hero-card-stats { display: flex; align-items: center; width: 100%; border-top: 0.5px solid var(--border); padding-top: 1rem; margin-top: 0.4rem; }
.stat-item { flex: 1; text-align: center; }
.stat-num { display: block; font-size: 17px; font-weight: 600; color: var(--text); letter-spacing: -0.02em; }
.stat-label { font-size: 9px; color: var(--muted); letter-spacing: 0.05em; text-transform: uppercase; }
.stat-div { width: 0.5px; height: 28px; background: var(--border2); }

@media (max-width: 820px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-visual { display: none; }
  h1 { font-size: 40px; }
  .hero-section { padding: 4rem 0 3.5rem; }
}
</style>
